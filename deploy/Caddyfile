# =============================================================================
# ADHERE+ — Caddy site config
#
# THIS FILE OWNS ONLY ADHERE+. It must never contain another project's config.
#
# The droplet also serves other, unrelated projects (e.g. hub.epichealthsystems.org).
# Those live in their OWN files under /srv/caddy-sites/ on the host, which is mounted
# read-only into the container at /etc/caddy/conf.d and pulled in by the import below.
#
# Why: this file is tracked in the ADHERE+ git repo. When another project's config was
# pasted in here by hand, `git pull` refused to run ("local changes would be
# overwritten"), so ADHERE+ silently stopped receiving deploys for days — and a
# `git checkout` to clear the conflict wiped the other project's config. Keeping each
# project in its own file removes that trap for good.
#
# To add another site:  create /srv/caddy-sites/<name>.caddy on the host.
#                       Do NOT edit this file.
# Reload after a change: docker compose exec caddy caddy reload --config /etc/caddy/Caddyfile
#                       (`docker compose up -d caddy` does NOT reload a bind-mounted config)
# =============================================================================

{$SITE_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
	}

	# The app shell must never be pinned in the browser's HTTP cache. Without this the
	# browser holds the OLD service-worker.js, never sees the new cache name, and keeps
	# serving a stale app.js — clients were found running a build four deploys old.
	# The service worker still does the offline caching; this only stops the HTTP layer
	# from pinning an old copy of the shell.
	@shell path / /index.html /app.js /service-worker.js /styles.css /config.js
	header @shell Cache-Control "no-cache, must-revalidate"

	reverse_proxy web:80
}

# Other projects on this droplet — each in its own file, outside this repo.
import /etc/caddy/conf.d/*.caddy
